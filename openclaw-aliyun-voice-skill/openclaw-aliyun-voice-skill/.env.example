# 必填：每个使用者都填自己的 AK/SK
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret

# 可选：STS 场景
# ALIBABA_CLOUD_SECURITY_TOKEN=your_security_token

# 可选：流控重试配置
ALIYUN_VOICE_MAX_RETRIES=5
ALIYUN_VOICE_BASE_BACKOFF_SECONDS=0.2
ALIYUN_VOICE_REQUEST_INTERVAL_SECONDS=0.01

# 可选：模板变量 equipment 的字符长度上限
EQUIPMENT_MAX_LENGTH=15
