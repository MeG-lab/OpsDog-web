# Frontend dev origin
OPSDOG_WEB_ORIGIN=http://127.0.0.1:4173

# Backend dev origin
OPSDOG_SERVER_ORIGIN=http://127.0.0.1:8787

# Frontend runtime API base path or full URL
VITE_API_BASE_URL=/api

# Default root for the built-in filesystem MCP server
VITE_OPSDOG_FILESYSTEM_ROOT=/Users/meteor/Code/OpsDog-Web

# Aliyun voice skill
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# ALIBABA_CLOUD_SECURITY_TOKEN=
ALIYUN_VOICE_MAX_RETRIES=5
ALIYUN_VOICE_BASE_BACKOFF_SECONDS=0.2
ALIYUN_VOICE_REQUEST_INTERVAL_SECONDS=0.01
EQUIPMENT_MAX_LENGTH=15

# Automatic voice alert notification
VITE_ALERT_VOICE_NOTIFY_ENABLED=false
VITE_ALERT_VOICE_NOTIFY_NUMBERS=

# Ticketing integration
TICKETING_CREATE_URL=
TICKETING_API_KEY=
TICKETING_SOURCE_SYSTEM=资产运维平台
TICKETING_DEFAULT_UNIT_NAME=南京市某单位
TICKETING_DEFAULT_PERSON_NAME=李四
TICKETING_DEFAULT_CONTACT_PHONE=13900000002
TICKETING_DEFAULT_ASSET_ID=ASSET-20260515-0002

# Asset device list integration
ASSET_API_MODE=local
ASSET_API_BASE_URL=
ASSET_API_LIST_PATH=
# ASSET_API_TOKEN=
