# Frontend dev origin
OPSDOG_WEB_ORIGIN=http://127.0.0.1:4175

# Backend dev origin
OPSDOG_SERVER_ORIGIN=http://127.0.0.1:8788

# 浏览器 Basic Auth
OPSDOG_BASIC_AUTH_USERNAME=admin
# OPSDOG_BASIC_AUTH_PASSWORD=

# 前端API
VITE_API_BASE_URL=/api

# 文件系统根目录
VITE_OPSDOG_FILESYSTEM_ROOT=.

# 语音配置
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# ALIBABA_CLOUD_SECURITY_TOKEN=

# 语音配置
ALIYUN_VOICE_MAX_RETRIES=5
ALIYUN_VOICE_BASE_BACKOFF_SECONDS=0.2
ALIYUN_VOICE_REQUEST_INTERVAL_SECONDS=0.01
EQUIPMENT_MAX_LENGTH=15

# 语音服务（网页配置）
VITE_ALERT_VOICE_NOTIFY_ENABLED=true
VITE_ALERT_VOICE_NOTIFY_NUMBERS=

# 工单相关内容
